{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "advanced",
  "model": "gpt-4o",
  "permission": {
    "edit": "allow",
    "bash": "allow",
    "read": "allow",
    "glob": "allow",
    "grep": "allow",
    "webfetch": "allow",
    "websearch": "allow",
    "question": "allow",
    "task": "allow",
    "external_directory": "allow"
  },
  "skills": {
    "paths": [".opencode-advanced/skills"]
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "command": ["npx", "-y", "@playwright/mcp"],
      "enabled": false
    }
  },
  "experimental": {
    "primary_tools": ["edit", "bash", "read", "glob", "grep", "webfetch", "websearch", "question", "task"],
    "mcp_timeout": 60000
  },
  "compaction": {
    "auto": true,
    "tail_turns": 30
  }
}
